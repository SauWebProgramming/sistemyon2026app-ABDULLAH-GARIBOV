@{
    ViewData["Title"] = "Öğrenci Profili";
}

<div style="display: flex; justify-content: center; align-items: center; height: 70vh; background-color: #f4f4f9;">
    <div style="background: white; padding: 40px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); text-align: center; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
        <h2 style="color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; margin-bottom: 20px;">
            Öğrenci Bilgi Sistemi
        </h2>

        <div style="font-size: 1.2em; color: #34495e; line-height: 1.8;">
            <p><strong>Öğrenci Numarası:</strong> @ViewBag.Student.GetProperty("studentNumber").GetString()</p>
            <p><strong>Ad:</strong> @ViewBag.Student.GetProperty("firstName").GetString()</p>
            <p><strong>Soyad:</strong> @ViewBag.Student.GetProperty("lastName").GetString()</p>
        </div>
    </div>
</div>